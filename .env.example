# Circuit Breaker — environment configuration
#
# EVERY variable here is OPTIONAL. With no keys set, the app runs in deterministic
# demo mode: all AI features return pre-authored, schema-valid responses so the app
# is fully explorable (and the whole test suite passes) with zero configuration.
#
# Keys are read ONLY in server-side route handlers. Never prefix an AI key with
# NEXT_PUBLIC_ — that would ship it to the browser.

# --- Primary generation provider: Groq (free tier ~14,400 req/day, very fast) ---
# Get one at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Fallback provider: Google Gemini (used automatically if Groq fails) ---
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Force deterministic demo mode even when keys are present (useful for demos/CI) ---
# Any value other than "true" is treated as false.
DEMO_MODE=false

# --- Public: shown in the UI so users can see which engine answered ---
NEXT_PUBLIC_APP_NAME=Circuit Breaker
