<mxfile host="app.diagrams.net" modified="2026-07-18T09:00:00.000Z" agent="Circuit Breaker" version="24.0.0">
  <diagram id="flow" name="User Flow">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1650" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t" value="Circuit Breaker — The Urge Flow" style="text;html=1;fontSize=26;fontStyle=1;align=left;fontColor=#1C2B2D;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="640" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="One urge, from cue to learning. The dark path is the safety route and it always wins." style="text;html=1;fontSize=13;align=left;fontColor=#4A5C5E;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="900" height="24" as="geometry" />
        </mxCell>

        <mxCell id="cue" value="CUE&#10;Boredom hits at 11pm.&#10;Hand reaches for phone." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EEF3;strokeColor=#5A6E8C;strokeWidth=2;fontSize=12;fontColor=#3A4A63;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="airlock" value="/airlock — ROUTE THE URGE&#10;&#10;State the intent, name the trigger,&#10;rate the intensity.&#10;&#10;A browser cannot block other apps.&#10;It intercepts the INTENT instead, and&#10;that deliberate pause between cue and&#10;routine IS the intervention." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDF9;strokeColor=#5A6E8C;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;fontColor=#1C2B2D;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="90" width="280" height="150" as="geometry" />
        </mxCell>

        <mxCell id="crisis" value="CRISIS GATE&#10;Keyword screen, runs on the server&#10;BEFORE any model sees the text" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F6E4DC;strokeColor=#8F3F22;strokeWidth=3;fontSize=11;fontStyle=1;fontColor=#8F3F22;" vertex="1" parent="1">
          <mxGeometry x="660" y="80" width="260" height="170" as="geometry" />
        </mxCell>

        <mxCell id="crisisOut" value="STOP. DO NOT COACH.&#10;&#10;Verified helplines only:&#10;988 · 741741 · Tele-MANAS 14416&#10;Samaritans 116 123 · findahelpline&#10;&#10;Deterministic and keyword-based on&#10;purpose: instant, offline, and&#10;impossible to talk out of." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16303C;strokeColor=#16303C;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;fontColor=#EAF2F2;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="990" y="80" width="280" height="170" as="geometry" />
        </mxCell>

        <mxCell id="score" value="SCORE THE MOMENT — pure function, no model, no network&#10;&#10;craving strength 30 · time of day 18 · trigger history 18&#10;sleep + stress 16 · habit maturity 10 · urge clustering 8&#10;&#10;→ 0-100, with every factor shown to the user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0EC;strokeColor=#3E5A48;strokeWidth=3;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;fontSize=12;fontColor=#3E5A48;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="320" y="300" width="600" height="130" as="geometry" />
        </mxCell>

        <mxCell id="adapt" value="THE INTERFACE ADAPTS TO WHAT IT FOUND" style="text;html=1;fontSize=14;fontStyle=1;align=center;fontColor=#1C2B2D;" vertex="1" parent="1">
          <mxGeometry x="320" y="450" width="600" height="30" as="geometry" />
        </mxCell>

        <mxCell id="steady" value="STEADY  0-24&#10;&#10;Full interface.&#10;Everything available.&#10;Plans, insights, coach." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EEF3;strokeColor=#5A6E8C;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;fontColor=#3A4A63;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="495" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="tempted" value="TEMPTED  25-54&#10;&#10;Surface warms.&#10;Relevant if-then plan&#10;surfaces first." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5EAD8;strokeColor=#B0803A;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;fontColor=#7A5520;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="425" y="495" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="high" value="HIGH RISK  55+&#10;&#10;Secondary panels recede.&#10;Fewer choices, bigger&#10;targets, less stimulation&#10;exactly when stimulation&#10;is the problem." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6E4DC;strokeColor=#8F3F22;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;fontColor=#8F3F22;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="495" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="gen" value="GENERATE THE INTERVENTION&#10;&#10;Groq writes an urge-surfing script for THIS trigger and THIS moment.&#10;Spoken aloud, paced against a breathing guide, about 90 seconds.&#10;&#10;Gemini catches it if Groq drops. A hand-written engine catches it if both do,&#10;so this step never fails and never blocks the user." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDF9;strokeColor=#5A6E8C;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;fontSize=12;fontColor=#1C2B2D;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="320" y="655" width="600" height="130" as="geometry" />
        </mxCell>

        <mxCell id="outcome" value="WHAT HAPPENED?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF3;strokeColor=#5A6E8C;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#3A4A63;" vertex="1" parent="1">
          <mxGeometry x="500" y="815" width="240" height="90" as="geometry" />
        </mxCell>

        <mxCell id="rode" value="RODE IT OUT&#10;&#10;Credits the plan that&#10;defended you, so plans&#10;earn a track record." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0EC;strokeColor=#3E5A48;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;fontColor=#3E5A48;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="180" y="945" width="230" height="110" as="geometry" />
        </mxCell>

        <mxCell id="lapsed" value="LAPSED&#10;&#10;Blame-free post-mortem.&#10;Finds the mechanism,&#10;writes a better plan.&#10;&#10;The streak does NOT reset.&#10;Lally 2010: missing one day&#10;does not reset the curve." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5EAD8;strokeColor=#7A5520;strokeWidth=2;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;fontColor=#7A5520;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="830" y="945" width="230" height="145" as="geometry" />
        </mxCell>

        <mxCell id="learn" value="EVERY OUTCOME FEEDS THE NEXT SCORE&#10;&#10;/journal every urge · /insights trigger + hour map · /trends is it working&#10;/plans rewrite themselves · /simulator explore the model yourself&#10;&#10;The trigger-history factor reads this log directly, so the model gets sharper&#10;about YOU with every single pass. That is the loop closing." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16303C;strokeColor=#16303C;align=left;verticalAlign=top;spacingLeft=16;spacingTop=12;fontSize=12;fontColor=#EAF2F2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="430" y="945" width="380" height="145" as="geometry" />
        </mxCell>

